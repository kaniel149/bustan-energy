# ============================================================
# solar-intelligence — environment variables
# Copy to .env for local dev; set in Vercel dashboard for prod.
# Server-side vars (no VITE_ prefix) are only available to api/.
# ============================================================

# ── Supabase (required) ─────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
# Default sender for transactional emails (proposals, follow-ups)
RESEND_FROM="Bustan Energy <contracts@bustan.energy>"
# Sender for the drip sequence (cron-email-queue); falls back to
# RESEND_FROM, then to "Bustan Energy <proposals@energy-tm.com>"
EMAIL_FROM="Bustan Energy <proposals@energy-tm.com>"
EMAIL_REPLY_TO=erez@energy-tm.com
# Internal notification recipients for new website leads
LEAD_NOTIFY_EMAILS=erez@energy-tm.com,kaniel@energy-tm.com

# ── Email drip (optional overrides) ─────────────────────────
SITE_URL=https://energy-tm.com
CONTACT_WHATSAPP="+66 94 669 2011"

# ── Cron auth (required — crons hard-fail without it) ───────
CRON_SECRET=

# ── Admin access ────────────────────────────────────────────
ADMIN_EMAILS=
ADMIN_EMAIL_DOMAINS=energy-tm.com
PROPOSAL_SESSION_SECRET=

# ── Third-party APIs ────────────────────────────────────────
GEMINI_API_KEY=
NANOBANANA_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
FIRECRAWL_API_KEY=
DBD_API_KEY=
DBD_AUTH_SCHEME=
OVERPASS_URL=
BOM_TEMPLATES_URL=

# ── Bustan secondary Supabase (password sync) ───────────────
BUSTAN_SUPABASE_URL=
BUSTAN_SUPABASE_SERVICE_ROLE_KEY=

# ── Frontend (Vite) ─────────────────────────────────────────
VITE_MAPBOX_TOKEN=
VITE_POSTHOG_KEY=
VITE_GA4_MEASUREMENT_ID=
