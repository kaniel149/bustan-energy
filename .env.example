# ── Supabase (server + client) ──────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Bustan Energy <contracts@bustan.energy>

# ── Cron auth (required — crons fail hard without it) ───────
CRON_SECRET=

# ── WhatsApp follow-ups (GreenAPI) ──────────────────────────
# Optional: when unset, the WhatsApp phase of /api/cron-followups is a no-op.
# Instance ID + API token from the GreenAPI console.
GREENAPI_INSTANCE_ID=
GREENAPI_TOKEN=
# Optional override; defaults to https://{first-4-digits}.api.greenapi.com
# GREENAPI_API_URL=https://7107.api.greenapi.com
# Team number (Erez/Kaniel) notified on every client nudge, intl digits, e.g. 66946692011
WA_TEAM_PHONE=
# Days after first view (proposal still unsigned) before the WhatsApp nudge. Default 2.
WA_FOLLOWUP_DAYS=2

# ── Misc ────────────────────────────────────────────────────
PROPOSAL_BASE_URL=https://energy-tm.com
VITE_MAPBOX_TOKEN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
