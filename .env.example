# ============================================================
# Bustan Energy (energy-tm.com) — environment variables
# Copy to .env for local dev; set in Vercel Dashboard for prod.
# ALL tracking vars are optional — every module no-ops gracefully
# when its var is missing.
# ============================================================

# ── Supabase (server — api/ functions) ──────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Bustan CRM secondary project (optional)
BUSTAN_SUPABASE_URL=
BUSTAN_SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase (client — Vite) ─────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_BUSTAN_SUPABASE_URL=
VITE_BUSTAN_SUPABASE_ANON_KEY=

# ── Analytics (client) ───────────────────────────────────────
# GA4 measurement id (G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=
# PostHog (injected at build time via vite.config.ts plugin)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Meta Pixel + CAPI (optional — pending Meta business verification) ──
# Browser pixel; PageView + Lead events fire only when set.
VITE_META_PIXEL_ID=
# Server-side Conversions API (api/_lib/meta-capi.ts). Both required to enable.
META_PIXEL_ID=
# System User token with ads_management permission
META_ACCESS_TOKEN=
# Optional: TESTxxxxx code from Events Manager > Test Events. REMOVE in prod.
META_TEST_EVENT_CODE=

# ── Google Ads (optional — for paid campaigns) ───────────────
# AW-XXXXXXXXXX
VITE_GOOGLE_ADS_ID=
# Conversion label for the Lead action (the part after AW-XXXX/)
VITE_GOOGLE_ADS_LEAD_CONVERSION_LABEL=

# ── Maps / data tools ────────────────────────────────────────
VITE_MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GEMINI_API_KEY=
NANOBANANA_API_KEY=
FIRECRAWL_API_KEY=
DBD_API_KEY=
DBD_AUTH_SCHEME=
OVERPASS_URL=
BOM_TEMPLATES_URL=

# ── Email / leads ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Bustan Energy Leads <leads@energy-tm.com>
LEAD_NOTIFY_EMAILS=erez@energy-tm.com,kaniel@energy-tm.com

# ── Admin / auth ─────────────────────────────────────────────
ADMIN_EMAILS=
ADMIN_EMAIL_DOMAINS=energy-tm.com
VITE_ADMIN_EMAILS=
VITE_ADMIN_EMAIL_DOMAINS=energy-tm.com
PROPOSAL_SESSION_SECRET=
CRON_SECRET=

# ── Misc ─────────────────────────────────────────────────────
VITE_LINE_OA_ID=
