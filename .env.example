# ============================================================
# Bustan Energy (energy-tm.com) — environment variables
# Copy to .env for local dev; set in Vercel Dashboard for prod.
# Server-side vars (no VITE_ prefix) are only available to api/.
# ALL tracking vars are optional — every module no-ops gracefully
# when its var is missing.
# ============================================================

# ── Supabase (required) ─────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Bustan secondary Supabase (password sync) ───────────────
BUSTAN_SUPABASE_URL=
BUSTAN_SUPABASE_SERVICE_ROLE_KEY=
VITE_BUSTAN_SUPABASE_URL=
VITE_BUSTAN_SUPABASE_ANON_KEY=

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
# Default sender for transactional emails (proposals, follow-ups, leads)
RESEND_FROM="Bustan Energy Leads <leads@energy-tm.com>"
# Sender for the drip sequence (cron-email-queue); falls back to
# RESEND_FROM, then to "Bustan Energy <proposals@energy-tm.com>"
EMAIL_FROM="Bustan Energy <proposals@energy-tm.com>"
EMAIL_REPLY_TO=erez@energy-tm.com
# Internal notification recipients for new website leads
LEAD_NOTIFY_EMAILS=erez@energy-tm.com,kaniel@energy-tm.com

# ── Email drip (optional overrides) ─────────────────────────
SITE_URL=https://energy-tm.com
CONTACT_WHATSAPP="+66 94 669 2011"

# ── Cron auth (required — crons hard-fail without it) ───────
CRON_SECRET=

# ── Admin access ────────────────────────────────────────────
ADMIN_EMAILS=
ADMIN_EMAIL_DOMAINS=energy-tm.com
VITE_ADMIN_EMAILS=
VITE_ADMIN_EMAIL_DOMAINS=energy-tm.com
PROPOSAL_SESSION_SECRET=

# ── Analytics (client) ───────────────────────────────────────
# GA4 measurement id (G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=
# PostHog (injected at build time via vite.config.ts plugin)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Meta Pixel + CAPI (optional — pending Meta business verification) ──
# Browser pixel; PageView + Lead events fire only when set.
VITE_META_PIXEL_ID=
# Server-side Conversions API (api/_lib/meta-capi.ts). Both required to enable.
META_PIXEL_ID=
# System User token with ads_management permission
META_ACCESS_TOKEN=
# Optional: TESTxxxxx code from Events Manager > Test Events. REMOVE in prod.
META_TEST_EVENT_CODE=

# ── Google Ads (optional — for paid campaigns) ───────────────
# AW-XXXXXXXXXX
VITE_GOOGLE_ADS_ID=
# Conversion label for the Lead action (the part after AW-XXXX/)
VITE_GOOGLE_ADS_LEAD_CONVERSION_LABEL=

# ── Maps / data tools ────────────────────────────────────────
VITE_MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GEMINI_API_KEY=
NANOBANANA_API_KEY=
FIRECRAWL_API_KEY=
DBD_API_KEY=
DBD_AUTH_SCHEME=
OVERPASS_URL=
BOM_TEMPLATES_URL=

# ── WhatsApp follow-ups (GreenAPI) ──────────────────────────
# Optional: when unset, the WhatsApp phase of /api/cron-followups is a no-op.
# Instance ID + API token from the GreenAPI console.
GREENAPI_INSTANCE_ID=
GREENAPI_TOKEN=
# Optional override; defaults to https://{first-4-digits}.api.greenapi.com
# GREENAPI_API_URL=https://7107.api.greenapi.com
# Team number (Erez/Kaniel) notified on every client nudge, intl digits, e.g. 66946692011
WA_TEAM_PHONE=
# Days after first view (proposal still unsigned) before the WhatsApp nudge. Default 2.
WA_FOLLOWUP_DAYS=2

# ── Misc ─────────────────────────────────────────────────────
PROPOSAL_BASE_URL=https://energy-tm.com
VITE_LINE_OA_ID=
