{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps",
  "build": {
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "headers": [
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/crm/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/platform/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/p/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/proposals/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/proposal-templates/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/p/:ref", "destination": "/api/proposal-serve?ref=:ref" },
    { "source": "/proposal-templates/:path*", "destination": "/proposal-templates/:path*" },
    { "source": "/proposals/:path*", "destination": "/proposals/:path*" },
    { "source": "/tools/:path*", "destination": "/tools/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-followups",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron-pea-followups",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-process-scans",
      "schedule": "*/10 * * * *"
    }
  ]
}
