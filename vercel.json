{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps",
  "build": {
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "rewrites": [
    { "source": "/tools/:path*", "destination": "/tools/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
