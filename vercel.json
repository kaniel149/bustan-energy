{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps",
  "build": {
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/p/:ref", "destination": "/api/proposal-serve?ref=:ref" },
    { "source": "/proposal-templates/:path*", "destination": "/proposal-templates/:path*" },
    { "source": "/proposals/:path*", "destination": "/proposals/:path*" },
    { "source": "/tools/:path*", "destination": "/tools/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-followups",
      "schedule": "0 10 * * *"
    }
  ]
}
